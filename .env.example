# ============================================================
# Estimator Pro — Environment Variables
# ============================================================
# Copy this file to `.env.local` in your project root.
# In Lovable: Settings → Environment Variables → add each key.
# NEVER commit .env.local to git.
# ============================================================


# ── SUPABASE ─────────────────────────────────────────────────────
#
# Where to find these:
#   Supabase Dashboard → Your Project → Settings → API
#
# NEXT_PUBLIC_* vars are safe to expose to the browser.
# The service role key is server-only — keep it secret!

# Project URL  (always safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon / public key  (safe to expose — RLS protects the data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key  (SECRET — server-side only, bypasses RLS)
# Use only in trusted server contexts (e.g. admin scripts).
# Do NOT prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── STRIPE ───────────────────────────────────────────────────────
#
# Where to find these:
#   Stripe Dashboard → Developers → API keys
#   Use TEST keys during development, LIVE keys in production.

# Secret key  (server-side only — never expose to browser)
STRIPE_SECRET_KEY=sk_test_...

# Publishable key  (safe to expose — used if you add Stripe.js)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Pre-created 27% TaxRate ID
#   Create once: Stripe Dashboard → Billing → Tax rates → + New
#   Set: Display name "ÁFA", Rate 27%, Country HU, Inclusive: No
STRIPE_TAX_RATE_ID=txr_...

# Webhook secret  (for verifying Stripe → your server events)
#   Stripe Dashboard → Developers → Webhooks → Add endpoint
#   Endpoint URL: https://your-app.lovable.app/api/stripe/webhook
#   Events to listen: invoice.payment_succeeded, invoice.sent
#   Then copy the "Signing secret" here.
STRIPE_WEBHOOK_SECRET=whsec_...


# ── APP ──────────────────────────────────────────────────────────

# The public URL of your deployed app (no trailing slash).
# Used for Supabase email redirect and Stripe webhook registration.
# In Lovable this is your project's preview/production URL.
NEXT_PUBLIC_APP_URL=https://your-app.lovable.app


# ── OPTIONAL: EMAIL (Resend) ─────────────────────────────────────
# Only needed if you add transactional email (quote delivery, etc.)
#   resend.com → API Keys → Create API Key
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=arajanlat@yourdomain.hu
